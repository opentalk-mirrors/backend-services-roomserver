          "editorMode": "code",
          "exemplar": false,
          "expr": "avg(last_over_time(k6_fairness_echo_responses_total{test_name=\"$fairness_test\"}[$__range]))",
          "instant": true,
          "legendFormat": "average",
          "range": false,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "exemplar": false,
          "expr": "last_over_time(k6_fairness_echo_responses_total{test_name=\"$fairness_test\"}[$__range])",
          "format": "table",
          "instant": true,
          "legendFormat": "total responses",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Echo response count deviation",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "mode": "inner"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "difference %",
            "mode": "reduceRow",
            "reduce": {
              "include": ["Value 2", "average"],
              "reducer": "diffperc"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "diffference _abs",
            "mode": "unary",
            "reduce": {
              "reducer": "sum"
            },
            "replaceFields": false,
            "unary": {
              "fieldName": "difference %",
              "operator": "abs"
            }
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": ["vu", "diffference _abs"]
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "desc": false,
                "field": "diffference _abs"
              }
            ]
          }
        }
      ],
      "type": "barchart"
    },
